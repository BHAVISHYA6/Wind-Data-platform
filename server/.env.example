# ── Server ────────────────────────────────────────────────────────
PORT=5000

# ── Database ──────────────────────────────────────────────────────
# Local MongoDB:
#   MONGODB_URI=mongodb://localhost:27017/wind_platform
# MongoDB Atlas:
#   MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/wind_platform
# Azure Cosmos DB for MongoDB:
#   MONGODB_URI=mongodb://<user>:<password>@<host>.mongo.cosmos.azure.com:10255/wind_platform?ssl=true
MONGODB_URI=mongodb://localhost:27017/wind_platform

# ── CORS ─────────────────────────────────────────────────────────
# URL of the frontend (used to restrict CORS + Socket.IO origin)
FRONTEND_URL=http://localhost:5173

# ── Environment ───────────────────────────────────────────────────
NODE_ENV=development
